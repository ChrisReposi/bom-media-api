# ==========================================================
# Root env example for local development.
# Copy per app when implementing.
# Never commit real .env files.
# ==========================================================

# Shared
NODE_ENV=development
APP_ENV=local

# API
API_HOST=0.0.0.0
API_PORT=3000
API_PREFIX=api/v1
API_PUBLIC_BASE_URL=http://localhost:3000/api/v1
API_INTERNAL_DOCS_ENABLED=true
# Production docs require both API_INTERNAL_DOCS_ENABLED=true and API_DOCS_ALLOW_IN_PRODUCTION=true.
API_DOCS_ALLOW_IN_PRODUCTION=false

# Database
# Hostinger managed hosting usually provides MySQL/MariaDB-compatible DB.
# Local Docker dev:
DATABASE_URL=mysql://video_share_user:video_share_password@127.0.0.1:3307/video_share_cms_dev
SHADOW_DATABASE_URL=mysql://video_share_user:video_share_password@127.0.0.1:3307/video_share_cms_shadow
# SHADOW_DATABASE_URL is for local prisma migrate dev only. Production uses migrate deploy.
# Production Hostinger example:
# DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME
DB_CONNECTION_LIMIT=5
DB_CONNECT_TIMEOUT_MS=10000
DB_ACQUIRE_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_SECONDS=60

# Admin Auth
# Rotate all placeholder secrets before production. Refresh tokens are opaque;
# JWT_REFRESH_SECRET/JWT_REFRESH_EXPIRES_IN are deprecated and intentionally unused.
ADMIN_REGISTER_SECRET=ma-bi-mat-ko-ai-biet
ADMIN_REGISTER_ENABLED=true
ADMIN_CHANGE_PASSWORD_SECRET=replace-with-long-random-change-password-secret
JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=12345
REFRESH_TOKEN_BYTES=32
REFRESH_TOKEN_PEPPER=replace-with-long-random-refresh-token-pepper
REFRESH_TOKEN_EXPIRES_DAYS=30

# Rate limits
GLOBAL_THROTTLE_TTL_SECONDS=60
GLOBAL_THROTTLE_LIMIT=120
AUTH_LOGIN_THROTTLE_TTL_SECONDS=60
AUTH_LOGIN_THROTTLE_LIMIT=5
AUTH_REFRESH_THROTTLE_TTL_SECONDS=60
AUTH_REFRESH_THROTTLE_LIMIT=20
AUTH_LOGOUT_THROTTLE_TTL_SECONDS=60
AUTH_LOGOUT_THROTTLE_LIMIT=30
ADMIN_API_THROTTLE_TTL_SECONDS=60
ADMIN_API_THROTTLE_LIMIT=120
PUBLIC_WATCH_THROTTLE_TTL_SECONDS=60
PUBLIC_WATCH_THROTTLE_LIMIT=60
PUBLIC_MEDIA_THROTTLE_TTL_SECONDS=60
PUBLIC_MEDIA_THROTTLE_LIMIT=1200

# Proxy handling
# Enable only when the API is actually behind a trusted reverse proxy path.
TRUST_PROXY_ENABLED=false
TRUST_PROXY_HOPS=1
TRUST_PROXY_CLOUDFLARE_ONLY=false

# CORS
ADMIN_WEB_ORIGIN=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5500,http://127.0.0.1:5500

# In production, keep static trusted origins here. Public website origins can
# come from ACTIVE assigned CMS domains when CORS_ALLOW_DB_DOMAINS=true.
# CORS_ALLOWED_ORIGINS=https://api.yourdomain.com,https://admin.yourdomain.com

CORS_ALLOW_DB_DOMAINS=true
CORS_DB_ORIGIN_CACHE_TTL_MS=60000
CORS_ALLOW_LOCALHOST_DB_DOMAINS=true
API_SELF_ORIGIN=http://localhost:3000

# Public Link
SHARE_TOKEN_BYTES=32
SHARE_TOKEN_PEPPER=replace-with-long-random-secret-before-production
ACCESS_LOG_IP_PEPPER=replace-with-long-random-ip-hash-pepper
PUBLIC_SITE_PROTOCOL=https
# Used when building local share URLs for localhost/127.0.0.1 domains.
PUBLIC_SHARE_LOCAL_PROTOCOL=http
ALLOW_LOCALHOST_DOMAIN_CLAIM=true
DEFAULT_SHARE_LINK_EXPIRES_DAYS=0
DEFAULT_SHARE_LINK_MAX_VIEWS=0

# Public display view growth. Disabled by default in production unless set true.
VIDEO_VIEW_GROWTH_ENABLED=false
VIDEO_VIEW_MAX_INCREMENT_PER_EVENT=99
VIDEO_VIEW_MAX_INCREMENT_PER_VIDEO_HOUR=5000
VIDEO_VIEW_DEDUPE_WINDOW_MINUTES=15
VIDEO_VIEW_MIN_WATCH_SECONDS=5
VIDEO_VIEW_RANDOM_MIN_INCREMENT=1

# Video Provider
# manual | bunny | mux | cloudinary
VIDEO_PROVIDER=manual
VIDEO_EMBED_ALLOWED_HOSTS=player.cloudinary.com,www.youtube.com,www.youtube-nocookie.com,player.vimeo.com
VIDEO_EMBED_DEFAULT_ALLOW=autoplay; fullscreen; encrypted-media; picture-in-picture
VIDEO_METADATA_PROBE_ENABLED=true
VIDEO_METADATA_PROBE_TIMEOUT_MS=8000
VIDEO_METADATA_PROBE_MAX_REMOTE_MB=100
# Strict DB upload fallback. Keep disabled for normal production.
# Local testing may use VIDEO_DB_UPLOAD_MAX_MB=100; values above 100 are rejected.
VIDEO_DB_STORAGE_ENABLED=false
VIDEO_DB_STORAGE_ALLOW_PRODUCTION_OVERRIDE=false
VIDEO_DB_UPLOAD_MAX_MB=100

# Hostinger/private NVMe local-file video storage.
# Keep LOCAL_FILE_STORAGE_ROOT outside public_html/public web roots.
LOCAL_FILE_STORAGE_ENABLED=false
LOCAL_FILE_STORAGE_ROOT=/home/<user>/bom-media-storage
LOCAL_VIDEO_UPLOAD_MAX_MB=500
LOCAL_VIDEO_UPLOAD_HARD_MAX_MB=1024
LOCAL_VIDEO_CHUNK_SIZE_MB=50
LOCAL_VIDEO_UPLOAD_SESSION_TTL_MINUTES=120
LOCAL_VIDEO_MIN_FREE_SPACE_MB=15360
LOCAL_VIDEO_STALE_UPLOAD_MAX_AGE_HOURS=24
LOCAL_THUMBNAIL_UPLOAD_MAX_MB=10

# Manual provider mode
MANUAL_VIDEO_URL_ALLOWLIST=

# Bunny Stream
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_PULL_ZONE_HOSTNAME=
BUNNY_STREAM_SIGNING_KEY=

# Mux
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY_BASE64=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_FOLDER=video-cms/videos
CLOUDINARY_THUMBNAIL_UPLOAD_FOLDER=video-cms/thumbnails
CLOUDINARY_SECURE=true
VIDEO_UPLOAD_MAX_MB=500
VIDEO_THUMBNAIL_UPLOAD_MAX_MB=5

# Admin Web
VITE_API_BASE_URL=http://localhost:3000/api/v1
# Enable only when the API has VIDEO_DB_STORAGE_ENABLED=true.
VITE_VIDEO_DB_UPLOAD_ENABLED=true
