CORS_ALLOW_DB_DOMAINS=true
CORS_DB_ORIGIN_CACHE_TTL_MS=60000
CORS_ALLOW_LOCALHOST_DB_DOMAINS=true
API_SELF_ORIGIN=http://localhost:3000

# In-memory backend cache. Process-local, optional, cleared on restart.
MEMORY_CACHE_ENABLED=true
