ADMIN_CHANGE_PASSWORD_SECRET=local-change-password-secret-change-me
ADMIN_ACCOUNT_MANAGEMENT_ENABLED=true
ADMIN_TEMP_PASSWORD_TTL_HOURS=24

JWT_ACCESS_SECRET=local-jwt-access-secret-change-me
