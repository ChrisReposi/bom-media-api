# Destructive-integration test environment (copy to .env.test).
#
# Points at the repository-owned local Docker MySQL only. The database name
# MUST end with _test or _scratch — scripts/safety/assert-destructive-test-database.ts
# hard-rejects anything else (including video_share_cms_dev and any remote
# host), so destructive FK proofs can never touch shared data again.
#
# Why DOTENV_CONFIG_PATH is required: src/config/load-env.ts gives .env.local
# override priority whenever APP_ENV=local (which the fallback .env sets), so
# an exported DATABASE_URL is silently replaced. An explicit
# DOTENV_CONFIG_PATH=.env.test is the deterministic way to select this file.
APP_ENV=test
DATABASE_URL=mysql://video_share_user:video_share_password@127.0.0.1:3307/video_share_cms_test
# Required, typed confirmation — the destructive proof refuses to start
# without it:
# ALLOW_DESTRUCTIVE_DB_TESTS=I_UNDERSTAND_THIS_DELETES_FIXTURES
