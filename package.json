{
  "name": "@video-share/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "dev:debug": "nest start --debug --watch",
    "dev:local": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local nest start --watch",
    "build": "prisma generate && nest build",
    "start": "node dist/main.js",
    "start:local": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local node dist/main.js",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"prisma/**/*.ts\" --fix",
    "test": "tsx --import ./test/test-env.ts --test test/*.test.ts",
    "audit:share-link-assignments": "tsx scripts/audit/share-link-assignment-audit.ts",
    "audit:admin-accounts": "tsx scripts/audit/admin-account-audit.ts",
    "audit:canonical-share-links": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local tsx scripts/audit/canonical-share-link-audit.ts",
    "remediate:local:adopt-canonical": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local tsx scripts/remediate/adopt-canonical-share-link.ts",
    "cleanup:admin-sessions": "tsx scripts/operations/cleanup-admin-sessions.ts",
    "remediate:local:website-video": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local tsx scripts/remediate/assign-local-website-video.ts",
    "smoke:local:share-link-assignment": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local tsx scripts/smoke/share-link-assignment-local-smoke.ts",
    "smoke:local:admin-accounts": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local tsx scripts/smoke/admin-account-local-smoke.ts",
    "format": "prettier --ignore-path .prettierignore --write \"src/**/*.ts\" \"prisma/**/*.ts\" \"*.ts\" \"*.json\"",
    "format:check": "prettier --ignore-path .prettierignore --check \"src/**/*.ts\" \"prisma/**/*.ts\" \"*.ts\" \"*.json\"",
    "check": "yarn typecheck && yarn lint && yarn format:check && yarn build",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "docker:local:up": "docker compose -f docker-compose.local.yml up -d",
    "docker:local:down": "docker compose -f docker-compose.local.yml down",
    "docker:local:logs": "docker compose -f docker-compose.local.yml logs -f mysql",
    "docker:local:reset": "docker compose -f docker-compose.local.yml down -v && docker compose -f docker-compose.local.yml up -d",
    "prisma": "prisma",
    "db:generate": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma generate",
    "db:validate": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma validate",
    "db:migrate:dev": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma migrate status",
    "db:studio": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma studio",
    "db:seed": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma db seed",
    "db:reset": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma migrate reset",
    "db:local:generate": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma generate",
    "db:local:validate": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma validate",
    "db:local:migrate": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma migrate dev",
    "db:local:deploy": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma migrate deploy",
    "db:local:status": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma migrate status",
    "db:local:seed": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma db seed",
    "db:local:reset": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma migrate reset",
    "db:local:studio": "cross-env APP_ENV=local DOTENV_CONFIG_PATH=.env.local prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/swagger": "11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "helmet": "^8.2.0",
    "multer": "2.2.0",
    "nestjs-pino": "^4.6.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prisma": "^7.8.0",
    "proxy-addr": "2.0.7",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "11.1.28",
    "@types/proxy-addr": "2.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.3"
  },
  "resolutions": {
    "@hono/node-server": "1.19.13"
  }
}
