generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

enum AdminRole {
  OWNER
  ADMIN
  STAFF
}

enum AccountStatus {
  ACTIVE
  DISABLED
}

enum VideoProvider {
  MANUAL
  BUNNY
  MUX
  CLOUDINARY
}

enum VideoSourceType {
  UPLOAD
  DIRECT_URL
  EMBED
  DB_BLOB
  LOCAL_FILE
}

enum VideoUploadSessionStatus {
  ACTIVE
  COMPLETING
  COMPLETED
  ABORTED
  EXPIRED
  FAILED
}

enum EmbedProvider {
  CLOUDINARY_PLAYER
  YOUTUBE
  YOUTUBE_NOCOOKIE
  VIMEO
  GENERIC_IFRAME
}

enum VideoStatus {
  DRAFT
  PROCESSING
  READY
  FAILED
  DISABLED
}

enum WebsiteStatus {
  ACTIVE
  DISABLED
}

enum WebsiteLanguage {
  VI
  EN
}

enum DomainStatus {
  ACTIVE
  DISABLED
}

enum DomainGroupStatus {
  ACTIVE
  DISABLED
}

enum ThemeStatus {
  ACTIVE
  DISABLED
}

enum AssignmentStatus {
  ACTIVE
  DISABLED
}

enum ShareLinkStatus {
  ACTIVE
  REVOKED
  EXPIRED
  DISABLED
}

enum AccessLogStatus {
  ALLOWED
  DENIED
}

enum AuditStatus {
  SUCCESS
  FAIL
}

model AdminUser {
  id           String        @id @default(cuid())
  username     String        @unique @db.VarChar(32)
  passwordHash String        @db.VarChar(255)
  role         AdminRole     @default(STAFF)
  status       AccountStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  refreshTokens AdminRefreshToken[]
  sessions      AdminSession[]
  auditLogs     AdminAuditLog[]
  uploadSessions VideoUploadSession[]

  @@index([status])
}

model AdminSession {
  id            String    @id @default(cuid())
  adminId       String
  expiresAt     DateTime
  revokedAt     DateTime?
  revokedReason String?   @db.VarChar(80)
  lastUsedAt    DateTime?
  ipHash        String?   @db.VarChar(128)
  userAgentHash String?   @db.VarChar(128)
  userAgent     String?   @db.VarChar(512)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  admin         AdminUser           @relation(fields: [adminId], references: [id], onDelete: Cascade)
  refreshTokens AdminRefreshToken[]

  @@index([adminId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AdminRefreshToken {
  id        String    @id @default(cuid())
  adminId   String
  sessionId String?
  tokenHash String    @unique @db.VarChar(128)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  admin   AdminUser     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  session AdminSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([sessionId])
  @@index([expiresAt])
}

model VideoAsset {
  id              String          @id @default(cuid())
  title           String          @db.VarChar(255)
  slug            String?         @unique @db.VarChar(160)
  description     String?         @db.Text
  provider        VideoProvider   @default(MANUAL)
  sourceType      VideoSourceType @default(DIRECT_URL)
  providerAssetId String?         @db.VarChar(255)
  playbackId      String?         @db.VarChar(255)
  playbackUrl     String?         @db.VarChar(2048)
  embedProvider   EmbedProvider?
  embedUrl        String?         @db.VarChar(2048)
  embedCloudName  String?         @db.VarChar(120)
  embedPublicId   String?         @db.VarChar(512)
  embedAllow      String?         @db.VarChar(255)
  thumbnailUrl    String?         @db.VarChar(2048)
  durationSeconds Int?
  viewCount       BigInt          @default(0)
  publishedAt     DateTime?
  status          VideoStatus     @default(DRAFT)
  filterKey       String?         @db.VarChar(64)
  metadataJson    Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  websiteVideos   WebsiteVideo[]
  shareLinkVideos ShareLinkVideo[]
  binaryAsset     VideoBinaryAsset?
  localFileAsset  VideoLocalFileAsset?
  localThumbnailAsset VideoLocalThumbnailAsset?
  uploadSessions  VideoUploadSession[]
  viewGrowthBuckets VideoViewGrowthBucket[]
  viewGrowthEvents  VideoViewGrowthEvent[]

  @@index([status])
  @@index([status, createdAt])
  @@index([filterKey])
  @@index([filterKey, status, createdAt])
  @@index([provider, providerAssetId])
  @@index([createdAt])
  @@index([publishedAt])
  @@index([slug])
}

model VideoBinaryAsset {
  id        String   @id @default(cuid())
  videoId   String   @unique
  mimeType  String   @db.VarChar(120)
  sizeBytes BigInt
  data      Bytes    @db.LongBlob
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  video VideoAsset @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
}

model VideoLocalFileAsset {
  id               String   @id @default(cuid())
  videoId          String   @unique
  storageKey       String   @unique @db.VarChar(512)
  originalFilename String   @db.VarChar(255)
  mimeType         String   @db.VarChar(120)
  sizeBytes        BigInt
  checksumSha256   String?  @db.VarChar(64)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  video VideoAsset @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([storageKey])
}

model VideoLocalThumbnailAsset {
  id               String   @id @default(cuid())
  videoId          String   @unique
  storageKey       String   @unique @db.VarChar(512)
  originalFilename String   @db.VarChar(255)
  mimeType         String   @db.VarChar(120)
  sizeBytes        BigInt
  checksumSha256   String?  @db.VarChar(64)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  video VideoAsset @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId])
  @@index([storageKey])
}

model VideoUploadSession {
  id               String                   @id @default(cuid())
  adminId          String
  videoId          String?
  title            String                   @db.VarChar(255)
  slug             String?                  @db.VarChar(160)
  description      String?                  @db.Text
  originalFilename String                   @db.VarChar(255)
  mimeType         String                   @db.VarChar(120)
  totalBytes       BigInt
  totalChunks      Int
  chunkSizeBytes   Int
  receivedChunks   Int                      @default(0)
  tempStorageKey   String                   @unique @db.VarChar(512)
  finalStorageKey  String?                  @db.VarChar(512)
  checksumSha256   String?                  @db.VarChar(64)
  status           VideoUploadSessionStatus @default(ACTIVE)
  expiresAt        DateTime
  completedAt      DateTime?
  abortedAt        DateTime?
  metadataJson     Json?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  admin  AdminUser   @relation(fields: [adminId], references: [id], onDelete: Cascade)
  video  VideoAsset? @relation(fields: [videoId], references: [id], onDelete: SetNull)
  chunks VideoUploadSessionChunk[]

  @@index([adminId])
  @@index([videoId])
  @@index([status])
  @@index([expiresAt])
}

model VideoUploadSessionChunk {
  id              String   @id @default(cuid())
  uploadSessionId String
  chunkIndex      Int
  storageKey      String   @unique @db.VarChar(512)
  sizeBytes       BigInt
  checksumSha256  String?  @db.VarChar(64)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  uploadSession VideoUploadSession @relation(fields: [uploadSessionId], references: [id], onDelete: Cascade)

  @@unique([uploadSessionId, chunkIndex])
  @@index([uploadSessionId])
  @@index([chunkIndex])
}

model VideoViewGrowthBucket {
  id             String   @id @default(cuid())
  videoId        String
  bucketStart    DateTime
  incrementTotal Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  video VideoAsset @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, bucketStart])
  @@index([bucketStart])
}

model VideoViewGrowthEvent {
  id          String   @id @default(cuid())
  videoId     String
  shareLinkId String?
  websiteId   String?
  viewerHash  String   @db.VarChar(128)
  windowStart DateTime
  increment   Int      @default(0)
  createdAt   DateTime @default(now())

  video VideoAsset @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([videoId, viewerHash, windowStart])
  @@index([videoId, createdAt])
  @@index([shareLinkId])
  @@index([websiteId])
}

model Website {
  id                 String          @id @default(cuid())
  name               String          @db.VarChar(255)
  slug               String          @unique @db.VarChar(120)
  defaultTitle       String?         @db.VarChar(255)
  defaultDescription String?         @db.Text
  domainGroupId      String?
  language           WebsiteLanguage @default(VI)
  status             WebsiteStatus   @default(ACTIVE)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  domainGroup   DomainGroup?    @relation(fields: [domainGroupId], references: [id], onDelete: SetNull)
  domains       WebsiteDomain[]
  themeConfig   ThemeConfig?
  websiteVideos WebsiteVideo[]
  shareLinks    ShareLink[]
  accessLogs    AccessLog[]

  @@index([status])
  @@index([domainGroupId])
}

model DomainGroup {
  id          String            @id @default(cuid())
  key         String            @unique @db.VarChar(80)
  name        String            @db.VarChar(160)
  description String?           @db.Text
  status      DomainGroupStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  websites Website[]
  domains  WebsiteDomain[]

  @@index([status])
}

model WebsiteDomain {
  id            String       @id @default(cuid())
  websiteId     String?
  domainGroupId String?
  domain        String       @unique @db.VarChar(253)
  isPrimary     Boolean      @default(false)
  status        DomainStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  website     Website?     @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  domainGroup DomainGroup? @relation(fields: [domainGroupId], references: [id], onDelete: SetNull)

  @@index([websiteId])
  @@index([domainGroupId])
  @@index([status])
}

model ThemeConfig {
  id          String      @id @default(cuid())
  websiteId   String      @unique
  themeKey    String      @db.VarChar(80)
  layoutKey   String      @db.VarChar(80)
  fontKey     String      @default("be-vietnam-pro") @db.VarChar(80)
  colorsJson  Json?
  fontsJson   Json?
  contentJson Json?
  customCss   String?     @db.Text
  status      ThemeStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  website Website @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([status])
}

model WebsiteVideo {
  id         String           @id @default(cuid())
  websiteId  String
  videoId    String
  sortOrder  Int              @default(0)
  isFeatured Boolean          @default(false)
  status     AssignmentStatus @default(ACTIVE)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  website Website    @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  video   VideoAsset @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([websiteId, videoId])
  @@index([websiteId])
  @@index([videoId])
  @@index([websiteId, sortOrder])
  @@index([status])
}

model ShareLink {
  id           String          @id @default(cuid())
  websiteId    String
  tokenHash    String          @unique @db.VarChar(128)
  alias        String?         @unique @db.VarChar(16)
  label        String?         @db.VarChar(255)
  expiresAt    DateTime?
  maxViews     Int?
  currentViews Int             @default(0)
  status       ShareLinkStatus @default(ACTIVE)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lastViewedAt DateTime?

  website         Website          @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  shareLinkVideos ShareLinkVideo[]
  accessLogs      AccessLog[]

  @@index([websiteId])
  @@index([status])
  @@index([websiteId, status])
  @@index([expiresAt])
}

model ShareLinkVideo {
  id          String   @id @default(cuid())
  shareLinkId String
  videoId     String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  shareLink ShareLink  @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  video     VideoAsset @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([shareLinkId, videoId])
  @@index([shareLinkId])
  @@index([videoId])
  @@index([shareLinkId, sortOrder])
}

model AccessLog {
  id          String          @id @default(cuid())
  websiteId   String?
  shareLinkId String?
  domain      String?         @db.VarChar(253)
  ipHash      String?         @db.VarChar(128)
  userAgent   String?         @db.VarChar(1024)
  referer     String?         @db.VarChar(2048)
  status      AccessLogStatus
  reasonCode  String?         @db.VarChar(80)
  createdAt   DateTime        @default(now())

  website   Website?   @relation(fields: [websiteId], references: [id], onDelete: SetNull)
  shareLink ShareLink? @relation(fields: [shareLinkId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([websiteId])
  @@index([shareLinkId])
  @@index([status])
}

model AdminAuditLog {
  id           String      @id @default(cuid())
  adminId      String?
  action       String      @db.VarChar(120)
  module       String      @db.VarChar(120)
  entityType   String?     @db.VarChar(120)
  entityId     String?     @db.VarChar(191)
  status       AuditStatus
  ipHash       String?     @db.VarChar(128)
  userAgent    String?     @db.VarChar(1024)
  metadataJson Json?
  createdAt    DateTime    @default(now())

  admin AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([adminId])
  @@index([module])
  @@index([entityType, entityId])
}
